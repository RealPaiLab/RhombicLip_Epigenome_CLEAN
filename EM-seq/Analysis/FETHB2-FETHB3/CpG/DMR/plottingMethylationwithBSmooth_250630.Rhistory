bsObj_full <- readBS(inDir = cytoDir, 
                  grepPattern = "\\.txt\\.gz$",
                  drop_hg38_alt = FALSE)
bs2 <- bsObj$bs
bsFull <- bsObj_full$bs
bsFull
unique(seqnames(bsFull))
phage <- subset(bsFull, GRanges(seqnames = "J02459.1", ranges = IRanges(1,48502))
)
phageGR <- GRanges(seqnames = "J02459.1", ranges = IRanges(1,48502))
phage <- subsetByOverlaps(bsFull, phageGR)
pdf("phage.pdf"); plotRegion(phage, region = data.frame(chr="J02459.1", start=1, end=2000))
phage_smoo <- BSmooth(phage)
dev.off()
pdf("phage.pdf"); plotRegion(phage, region = data.frame(chr="J02459.1", start=1, end=2000)); dev.off()
dev.off()
