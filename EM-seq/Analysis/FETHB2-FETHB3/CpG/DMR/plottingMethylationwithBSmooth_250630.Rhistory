head(x)
for (cur in unique(x$variable)) {
  cur2 <- x[which(x$variable == cur), ]
  # compute median difference methylation VZ - SVZ
  cur2$diff.Methy <- cur2$value[cur2$ROI == "VZ"] - cur2$value[cur2$ROI == "SVZ"]
  md <- median(cur2$diff.Methy, na.rm = TRUE)
  print(cur)
p <- ggplot(cur2, aes(x = ROI, y = value*100, fill = ROI)) +
  geom_boxplot(width=0.1) + 
  geom_point() +
  labs(title = sprintf("%s\n VZ - SVZ = %1.2f%%", cur, md*100),
       x = "Sample",
       y = "Percent Methylation")  +
  scale_fill_manual(values= c("VZ" = "#af8dc3", "SVZ" = "#7fbf7b")) + 
  theme_minimal(base_size = 12) +
  stat_n_text()
  ggsave(p,file=sprintf("%s.pdf",cur), 
         width = 4, height = 4)
}
for (cur in unique(x$variable)) {
  cur2 <- x[which(x$variable == cur), ]
  # compute median difference methylation VZ - SVZ
  md <- mean(cur2$value[which(cur2$ROI=="VZ")],na.rm=TRUE) - 
        mean(cur2$value[which(cur2$ROI=="SVZ")],na.rm=TRUE)
  print(cur)
p <- ggplot(cur2, aes(x = ROI, y = value*100, fill = ROI)) +
  geom_boxplot(width=0.1) + 
  geom_point() +
  labs(title = sprintf("%s\n VZ - SVZ = %1.2f%%", cur, md*100),
       x = "Sample",
       y = "Percent Methylation")  +
  scale_fill_manual(values= c("VZ" = "#af8dc3", "SVZ" = "#7fbf7b")) + 
  theme_minimal(base_size = 12) +
  stat_n_text()
  ggsave(p,file=sprintf("%s.pdf",cur), 
         width = 4, height = 4)
}
